# Vault root — passed as cwd to `claude -p`
# Use the absolute path to your Obsidian vault (or any working directory for Claude)
VAULT_ROOT=C:\Users\<you>\path\to\vault

# Full path to the claude CLI executable (not on PATH by default on Windows)
# Find it with: Get-ChildItem "$env:APPDATA\Claude" -Recurse -Filter "claude.exe"
# Update the version segment after Claude upgrades
CLAUDE_BIN=C:\Users\<you>\AppData\Roaming\Claude\claude-code\<version>\claude.exe

# Model to use for claude -p (leave empty to use the CLI default)
CLAUDE_MODEL=claude-sonnet-4-6

# Timeout for claude subprocess (seconds)
CLAUDE_TIMEOUT=300

# signal-cli-rest-api base URL (Docker container, loopback-bound on same machine)
SIGNAL_API_URL=http://127.0.0.1:8080

# Your own Signal number in E.164 format (the account paired in PAIRING.md)
SIGNAL_NUMBER=+1234567890

# Comma-separated E.164 numbers allowed to trigger Claude.
# Defaults to SIGNAL_NUMBER — messages from anyone else are silently dropped.
ALLOWED_SENDERS=+1234567890

# Poll interval for /v1/receive in seconds (3 is responsive without hammering the API)
POLL_INTERVAL=3

# Max tokens before classifying as freeform instead of a short research topic
SHORT_TOPIC_MAX_TOKENS=4
